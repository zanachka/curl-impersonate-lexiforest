+    lines[i].line = line;
+    lines[i].linelen = (size_t)(next - line);
+    colon = memchr(line, ':', (size_t)(next - line));
+    if(colon) {
+      lines[i].name = line;
+      lines[i].namelen = (size_t)(colon - line);
