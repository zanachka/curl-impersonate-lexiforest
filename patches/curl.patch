+
+static const char *http_header_block_end(const char *buf, size_t blen)
+{
+  size_t i;
+
+  for(i = 0; (i + 3) < blen; i++) {
+    if(buf[i] == '\r' && buf[i + 1] == '\n' &&
+       buf[i + 2] == '\r' && buf[i + 3] == '\n')
+      return &buf[i];
+  }
+  return NULL;
