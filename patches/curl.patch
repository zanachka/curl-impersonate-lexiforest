+static bool quic_has_empty_initial_scid(const char *params)
+{
+  const char *p = params;
+
+  if(!p || !*p)
+    return FALSE;
+
+  while(*p) {
+    const char *end;
+    size_t len;
+
+    while(*p == ';')
+      ++p;
+    if(!*p)
+      break;
+
+    end = strchr(p, ';');
+    len = end ? (size_t)(end - p) : strlen(p);
+    if((len == 3) && (p[0] == '1') && (p[1] == '5') && (p[2] == ':'))
+      return TRUE;
+
+    p = end ? (end + 1) : (p + len);
+  }
+
+  return FALSE;
+}
