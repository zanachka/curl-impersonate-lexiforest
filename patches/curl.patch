+  if(!h3_rand_u32(data, &n) || !h3_rand_u32(data, &value))
+    return FALSE;
+
+  iv->id = (H3_SETTINGS_GREASE_ID_STEP * (uint64_t)n) +
+           H3_SETTINGS_GREASE_ID_BASE;
+  iv->value = value;
+  return TRUE;
+}
