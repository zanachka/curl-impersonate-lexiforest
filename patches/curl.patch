+/* HTTP/3 GREASE setting identifiers follow: 0x1f * N + 0x21 */
+#define H3_SETTINGS_GREASE_ID_BASE  UINT64_C(0x21)
+#define H3_SETTINGS_GREASE_ID_STEP  UINT64_C(0x1f)
